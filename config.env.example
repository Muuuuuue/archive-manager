# ============================================
# 文件自动整理与编号归档系统 - 配置文件
# ============================================
# 复制此文件为 config.env 并填写实际值

# --------------------------------------------
# 邮箱配置 (163邮箱)
# --------------------------------------------
EMAIL_IMAP_SERVER=imap.163.com
EMAIL_SMTP_SERVER=smtp.163.com
EMAIL_USERNAME=your_email@163.com
# 注意：不是登录密码，是163邮箱的授权码
EMAIL_PASSWORD=your_auth_code_here

# --------------------------------------------
# 网页服务配置
# --------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# --------------------------------------------
# 管理员配置
# --------------------------------------------
# 管理员令牌（用于访问规则维护页面）
ADMIN_TOKEN=your_admin_token_here

# --------------------------------------------
# 周报配置
# --------------------------------------------
WEEKLY_REPORT_EMAIL=yiyao_liu2003@163.com
# 超过多少天未归档需要提醒
REMINDER_DAYS=7

# --------------------------------------------
# GitHub配置
# --------------------------------------------
GITHUB_REPO=https://github.com/Muuuuuue/-.git
GITHUB_BRANCH=main
# GitHub Personal Access Token
GITHUB_TOKEN=your_github_token_here

# --------------------------------------------
# 文件路径配置
# --------------------------------------------
# 临时文件夹（下载附件用）
TEMP_FOLDER=D:\temp\file_archive
# 数据库文件路径
DB_PATH=web_system\data\file_archive.db
# 分类规则表路径
RULES_EXCEL=file_organizer\data\classification_rules.xlsx
# 待分类文件夹（规则未找到时移动到这里）
PENDING_FOLDER=D:\temp\file_archive\pending
